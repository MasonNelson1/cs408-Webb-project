<div style="padding: 3rem 0;">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6">

        <div class="mb-4">
          <a href="/projects" style="color:rgba(255,255,255,0.5); text-decoration:none; font-size:0.9rem;">
            <i class="bi bi-arrow-left me-1"></i>All Projects
          </a>
        </div>

        <h2 style="color:#fff; font-weight:700; margin-bottom:0.25rem;">New Project</h2>
        <p style="color:rgba(255,255,255,0.4); margin-bottom:2rem; font-size:0.9rem;">Create a project to start tracking tasks.</p>

        <% if (error) { %>
          <div style="background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); border-radius:10px; padding:0.75rem 1rem; color:#f87171; margin-bottom:1.5rem; font-size:0.9rem;">
            <i class="bi bi-exclamation-circle me-2"></i><%= error %>
          </div>
        <% } %>

        <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(168,85,247,0.2); border-radius:14px; padding:2rem;">
          <form action="/projects" method="POST">
            <div class="mb-4">
              <label style="color:rgba(255,255,255,0.7); font-size:0.9rem; font-weight:500; display:block; margin-bottom:0.5rem;">Project Name</label>
              <input type="text" name="name" required autocomplete="off"
                style="background:rgba(255,255,255,0.07); border:1px solid rgba(168,85,247,0.25); border-radius:8px; color:#fff; padding:0.65rem 0.9rem; width:100%; font-size:0.95rem;"
                placeholder="e.g. My App, CS408 Final..." />
            </div>
            <div class="mb-4">
              <label style="color:rgba(255,255,255,0.7); font-size:0.9rem; font-weight:500; display:block; margin-bottom:0.5rem;">Description <span style="color:rgba(255,255,255,0.3); font-weight:400;">(optional)</span></label>
              <textarea name="description" rows="3"
                style="background:rgba(255,255,255,0.07); border:1px solid rgba(168,85,247,0.25); border-radius:8px; color:#fff; padding:0.65rem 0.9rem; width:100%; font-size:0.95rem; resize:vertical;"
                placeholder="What is this project about?"></textarea>
            </div>
            <button type="submit"
              style="background:linear-gradient(135deg,#a855f7,#7c3aed); color:#fff; font-weight:600; padding:0.7rem 1.5rem; border-radius:8px; border:none; width:100%; font-size:1rem; cursor:pointer;">
              <i class="bi bi-plus-lg me-1"></i>Create Project
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</div>
