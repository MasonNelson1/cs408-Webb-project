<div class="container py-5">

  <div class="mb-4">
    <a href="/projects" class="dt-back-link">
      <i class="bi bi-arrow-left me-1"></i>All Projects
    </a>
  </div>

  <div class="dt-detail-header mb-4">
    <div class="dt-detail-header-inner">
      <span class="dt-project-icon lg"><i class="bi bi-folder2-open"></i></span>
      <div>
        <h2 class="dt-page-title mb-1"><%= project.name %></h2>
        <p class="dt-page-sub mb-0"><%= project.description || 'No description provided.' %></p>
      </div>
    </div>
    <div class="dt-detail-stats">
  <% const open = tasks.filter(t => t.status === 'open').length %>
  <% const done = tasks.filter(t => t.status === 'complete').length %>
  <span class="dt-task-pill open"><i class="bi bi-circle me-1"></i><%= open %> open</span>
  <span class="dt-task-pill done"><i class="bi bi-check-circle me-1"></i><%= done %> done</span>
</div>
    </div>
  </div>
    <div style="margin-bottom:1rem;">
  <form action="/projects/<%= project.id %>/delete" method="POST" onsubmit="return confirm('Delete this project and all its tasks?')">
    <button type="submit" class="btn dt-btn-delete">
      <i class="bi bi-trash3 me-1"></i>Delete Project
    </button>
  </form>
</div>
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="dt-card">
        <div class="dt-card-header">
          <span class="fw-600">Tasks</span>
          <span class="dt-task-count"><%= tasks.length %> total</span>
        </div>

        <% if (tasks.length === 0) { %>
          <div class="dt-empty-state sm">
            <i class="bi bi-clipboard2 dt-empty-icon sm"></i>
            <p class="text-muted mb-0">No tasks yet. Add one below.</p>
          </div>
        <% } else { %>
          <ul class="dt-task-list">
            <% tasks.forEach(function(task) { %>
              <li class="dt-task-item <%= task.status === 'complete' ? 'completed' : '' %>">
                <div class="dt-task-left">
                  <% if (task.status === 'complete') { %>
                    <span class="dt-task-status-icon done"><i class="bi bi-check-circle-fill"></i></span>
                  <% } else { %>
                    <span class="dt-task-status-icon open"><i class="bi bi-circle"></i></span>
                  <% } %>
                  <span class="dt-task-title"><%= task.title %></span>
                </div>
                <div class="dt-task-actions">
                  <% if (task.status !== 'complete') { %>
                    <form action="/projects/<%= project.id %>/tasks/<%= task.id %>/complete" method="POST" class="d-inline">
                      <button type="submit" class="btn dt-btn-complete" title="Mark complete">
                        <i class="bi bi-check-lg me-1"></i>Complete
                      </button>
                    </form>
                  <% } %>
                  <form action="/projects/<%= project.id %>/tasks/<%= task.id %>/delete" method="POST" class="d-inline">
                    <button type="submit" class="btn dt-btn-delete" title="Delete task">
                      <i class="bi bi-trash3"></i>
                    </button>
                  </form>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="dt-card">
        <div class="dt-card-header">
          <span class="fw-600">Add Task</span>
        </div>
        <div class="p-3">
          <form action="/projects/<%= project.id %>/tasks" method="POST">
            <div class="mb-3">
              <input
                type="text"
                class="form-control dt-input"
                name="title"
                placeholder="Describe the task..."
                required
                autocomplete="off"
              />
            </div>
            <button type="submit" class="btn dt-btn-primary w-100">
              <i class="bi bi-plus-lg me-1"></i>Add Task
            </button>
          </form>
        </div>
      </div>

      <div class="dt-card mt-3">
        <div class="dt-card-header">
          <span class="fw-600">Project Info</span>
        </div>
        <div class="p-3">
          <div class="dt-info-row">
            <span class="dt-info-label">Created</span>
            <span class="dt-info-value"><%= new Date(project.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
          </div>
          <div class="dt-info-row">
            <span class="dt-info-label">Total Tasks</span>
            <span class="dt-info-value"><%= tasks.length %></span>
          </div>
          <% if (tasks.length > 0) { %>
          <div class="dt-info-row">
            <span class="dt-info-label">Progress</span>
            <span class="dt-info-value">
              <%= Math.round((tasks.filter(t => t.status === 'complete').length / tasks.length) * 100) %>%
            </span>
          </div>
          <div class="mt-3">
            <div class="dt-progress-bar">
              <div class="dt-progress-fill" style="width: <%= Math.round((tasks.filter(t => t.status === 'complete').length / tasks.length) * 100) %>%"></div>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

</div>
