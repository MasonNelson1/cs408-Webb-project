<div class="container py-5">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h2 class="dt-page-title mb-1">Projects</h2>
      <p class="dt-page-sub mb-0"><%= projects.length %> project<%= projects.length !== 1 ? 's' : '' %> total</p>
    </div>
    <a href="/projects/new" class="btn dt-btn-primary">
      <i class="bi bi-plus-lg me-1"></i>New Project
    </a>
  </div>

  <% if (projects.length === 0) { %>
    <div class="dt-empty-state">
      <i class="bi bi-folder2 dt-empty-icon"></i>
      <h5 class="mt-3 mb-1">No projects yet</h5>
      <p class="text-muted mb-4">Create your first project to start tracking tasks.</p>
      <a href="/projects/new" class="btn dt-btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Create Project
      </a>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% projects.forEach(function(project) { %>
        <div class="col-md-6 col-lg-4">
          <div class="dt-project-card">
            <div class="dt-project-card-header">
              <span class="dt-project-icon"><i class="bi bi-folder2-open"></i></span>
              <h5 class="dt-project-name mb-0"><%= project.name %></h5>
            </div>
            <p class="dt-project-desc">
              <%= project.description || 'No description provided.' %>
            </p>
            <div class="dt-project-meta">
              <span class="dt-task-pill open">
                <i class="bi bi-circle me-1"></i><%= project.task_count - project.completed_count %> open
              </span>
              <span class="dt-task-pill done">
                <i class="bi bi-check-circle me-1"></i><%= project.completed_count %> done
              </span>
            </div>
            <a href="/projects/<%= project.id %>" class="dt-project-link stretched-link">
              View Project <i class="bi bi-arrow-right ms-1"></i>
            </a>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
