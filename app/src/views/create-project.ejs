<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

      <div class="mb-4">
        <a href="/projects" class="dt-back-link">
          <i class="bi bi-arrow-left me-1"></i>Back to Projects
        </a>
      </div>

      <div class="dt-form-card">
        <div class="dt-form-card-header">
          <span class="dt-form-icon"><i class="bi bi-folder-plus"></i></span>
          <div>
            <h4 class="mb-0">New Project</h4>
            <p class="text-muted small mb-0">Fill in the details to create a project</p>
          </div>
        </div>

        <% if (error) { %>
          <div class="alert dt-alert-error" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
          </div>
        <% } %>

        <form action="/projects" method="POST">
          <div class="mb-4">
            <label for="name" class="dt-label">Project Name <span class="text-danger">*</span></label>
            <input
              type="text"
              class="form-control dt-input"
              id="name"
              name="name"
              placeholder="e.g. Personal Portfolio Site"
              required
              autocomplete="off"
            />
          </div>
          <div class="mb-4">
            <label for="description" class="dt-label">Description</label>
            <textarea
              class="form-control dt-input"
              id="description"
              name="description"
              rows="3"
              placeholder="What is this project about? (optional)"
            ></textarea>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn dt-btn-primary flex-grow-1">
              <i class="bi bi-plus-lg me-1"></i>Create Project
            </button>
            <a href="/projects" class="btn dt-btn-outline">Cancel</a>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
