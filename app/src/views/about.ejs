<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <div class="mb-4">
        <a href="/" class="dt-back-link">
          <i class="bi bi-arrow-left me-1"></i>Home
        </a>
      </div>

      <div class="dt-about-header mb-5">
        <span class="dt-about-icon"><i class="bi bi-kanban-fill"></i></span>
        <div>
          <h2 class="dt-page-title mb-1">About DevTrack</h2>
          <p class="dt-page-sub mb-0">A lightweight project and issue tracker</p>
        </div>
      </div>

      <div class="dt-card mb-4">
        <div class="p-4">
          <h5 class="dt-section-heading">What is DevTrack?</h5>
          <p>
            DevTrack is a simple, no-nonsense project tracker built for individual developers and small teams.
            It cuts through the complexity of enterprise tools like Jira or Asana and gives you exactly what you
            need: projects, tasks, and status.
          </p>
          <p class="mb-0">
            Create a project, add tasks to it, mark them complete, and delete them when they're done.
            That's it. No boards, no epics, no sprints — just the work.
          </p>
        </div>
      </div>

      <div class="dt-card mb-4">
        <div class="p-4">
          <h5 class="dt-section-heading">Tech Stack</h5>
          <div class="row g-3 mt-1">
            <% const stack = [
              { icon: 'bi-server', label: 'Node.js + Express', desc: 'Backend server & routing' },
              { icon: 'bi-database', label: 'SQLite (better-sqlite3)', desc: 'Persistent relational storage' },
              { icon: 'bi-file-code', label: 'EJS Templates', desc: 'Server-side HTML rendering' },
              { icon: 'bi-bootstrap', label: 'Bootstrap 5', desc: 'UI framework & layout' },
              { icon: 'bi-cloud-upload', label: 'AWS EC2', desc: 'Deployment environment' },
              { icon: 'bi-box-seam', label: 'Docker + Nginx', desc: 'Containerized deployment' },
            ] %>
            <% stack.forEach(function(item) { %>
              <div class="col-sm-6">
                <div class="dt-stack-item">
                  <i class="bi <%= item.icon %> dt-stack-icon"></i>
                  <div>
                    <div class="dt-stack-label"><%= item.label %></div>
                    <div class="dt-stack-desc"><%= item.desc %></div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <div class="dt-card">
        <div class="p-4">
          <h5 class="dt-section-heading">Course Context</h5>
          <p class="mb-0">
            DevTrack is built as the final project for CS408 Full Stack Web Development at Boise State University.
            It demonstrates a complete full-stack architecture: relational database design, RESTful routing,
            server-side rendering, containerized deployment, and automated end-to-end testing with Playwright.
          </p>
        </div>
      </div>

    </div>
  </div>
</div>
