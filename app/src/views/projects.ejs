<style>
  .dt-page-wrap { padding: 3rem 0; }
  .dt-project-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(168,85,247,0.2);
    border-radius: 14px;
    padding: 1.5rem;
    height: 100%;
    transition: border-color 0.2s, background 0.2s;
  }
  .dt-project-card:hover {
    background: rgba(168,85,247,0.08);
    border-color: rgba(168,85,247,0.5);
  }
  .dt-project-name { color: #fff; font-weight: 600; font-size: 1.05rem; }
  .dt-project-desc { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin: 0.5rem 0 1rem; }
  .dt-project-link { color: #a855f7; text-decoration: none; font-size: 0.9rem; font-weight: 500; }
  .dt-project-link:hover { color: #c084fc; }
  .dt-task-pill { font-size: 0.78rem; padding: 0.2rem 0.65rem; border-radius: 999px; font-weight: 500; }
  .dt-task-pill.open { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.25); }
  .dt-task-pill.done { background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
  .dt-empty-state { text-align: center; padding: 5rem 0; color: rgba(255,255,255,0.4); }
  .dt-btn-primary {
    background: linear-gradient(135deg, #a855f7, #7c3aed);
    color: #fff;
    font-weight: 600;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.9rem;
    border: none;
  }
  .dt-btn-primary:hover { opacity: 0.85; color: #fff; }
</style>

<div class="dt-page-wrap">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h2 style="color:#fff; font-weight:700; margin-bottom:0.25rem;">Projects</h2>
        <p style="color:rgba(255,255,255,0.4); margin:0; font-size:0.9rem;"><%= projects.length %> project<%= projects.length !== 1 ? 's' : '' %> total</p>
      </div>
      <a href="/projects/new" class="dt-btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Project
      </a>
    </div>

    <% if (projects.length === 0) { %>
      <div class="dt-empty-state">
        <i class="bi bi-folder2" style="font-size:3rem; color:rgba(168,85,247,0.4);"></i>
        <h5 style="color:rgba(255,255,255,0.6); margin-top:1rem;">No projects yet</h5>
        <p>Create your first project to start tracking tasks.</p>
        <a href="/projects/new" class="dt-btn-primary">
          <i class="bi bi-plus-lg me-1"></i>Create Project
        </a>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% projects.forEach(function(project) { %>
          <div class="col-md-6 col-lg-4">
            <div class="dt-project-card" onclick="window.location='/projects/<%= project.id %>'" style="cursor:pointer;">
              <div class="d-flex align-items-center gap-2 mb-1">
                <i class="bi bi-folder2-open" style="color:#a855f7;"></i>
                <span class="dt-project-name"><%= project.name %></span>
              </div>
              <p class="dt-project-desc"><%= project.description || 'No description provided.' %></p>
              <div class="d-flex gap-2 mb-3">
                <span class="dt-task-pill open"><i class="bi bi-circle me-1"></i><%= project.task_count - project.completed_count %> open</span>
                <span class="dt-task-pill done"><i class="bi bi-check-circle me-1"></i><%= project.completed_count %> done</span>
              </div>
              <a href="/projects/<%= project.id %>" class="dt-project-link">
                View Project <i class="bi bi-arrow-right ms-1"></i>
              </a>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>
