<style>
  .dt-detail-wrap { padding: 3rem 0; }
  .dt-back-link { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.9rem; }
  .dt-back-link:hover { color: #c084fc; }
  .dt-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(168,85,247,0.2);
    border-radius: 14px;
    margin-bottom: 1rem;
    overflow: hidden;
  }
  .dt-card-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(168,85,247,0.15);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    background: rgba(168,85,247,0.08) !important;
  }
  .dt-task-list { list-style: none; padding: 0; margin: 0; }
  .dt-task-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: relative;
  }
  .dt-task-item:last-child { border-bottom: none; }
  .dt-task-item:hover { background: rgba(168,85,247,0.08) !important; }
  .dt-task-item.completed .dt-task-title { text-decoration: line-through; color: rgba(255,255,255,0.3); }
  .dt-task-title { color: rgba(255,255,255,0.85); font-size: 0.95rem; }
  .dt-task-pill { font-size: 0.78rem; padding: 0.2rem 0.65rem; border-radius: 999px; font-weight: 500; }
  .dt-task-pill.open { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.25); }
  .dt-task-pill.done { background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
  .dt-input {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(168,85,247,0.25);
    border-radius: 8px;
    color: #fff;
    padding: 0.55rem 0.9rem;
    width: 100%;
    font-size: 0.95rem;
  }
  .dt-input::placeholder { color: rgba(255,255,255,0.3); }
  .dt-input:focus { outline: none; border-color: #a855f7; background: rgba(255,255,255,0.1); }
  .dt-btn-primary {
    background: linear-gradient(135deg, #a855f7, #7c3aed);
    color: #fff;
    font-weight: 600;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    border: none;
    width: 100%;
    cursor: pointer;
    font-size: 0.95rem;
  }
  .dt-btn-primary:hover { opacity: 0.85; }
  .dt-btn-delete {
    background: rgba(239,68,68,0.1);
    color: #f87171;
    border: 1px solid rgba(239,68,68,0.25);
    border-radius: 6px;
    padding: 0.25rem 0.6rem;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .dt-btn-delete:hover { background: rgba(239,68,68,0.2); }
  .dt-info-row {
    display: flex;
    justify-content: space-between;
    padding: 0.6rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 0.9rem;
  }
  .dt-info-row:last-child { border-bottom: none; }
  .dt-info-label { color: rgba(255,255,255,0.4); }
  .dt-info-value { color: rgba(255,255,255,0.85); font-weight: 500; }
  .dt-progress-bar { background: rgba(255,255,255,0.08); border-radius: 999px; height: 6px; margin: 0.5rem 1.25rem 1rem; }
  .dt-progress-fill { background: linear-gradient(135deg, #a855f7, #7c3aed); border-radius: 999px; height: 100%; }
</style>

<div class="dt-detail-wrap">
  <div class="container">

    <div class="mb-4">
      <a href="/projects" class="dt-back-link"><i class="bi bi-arrow-left me-1"></i>All Projects</a>
    </div>

    <div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
      <div class="d-flex align-items-center gap-3">
        <i class="bi bi-folder2-open" style="font-size:1.75rem; color:#a855f7;"></i>
        <div>
          <h2 style="color:#fff; font-weight:700; margin:0;"><%= project.name %></h2>
          <p style="color:rgba(255,255,255,0.45); margin:0; font-size:0.9rem;"><%= project.description || 'No description provided.' %></p>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <% const open = tasks.filter(t => t.status === 'open').length %>
        <% const done = tasks.filter(t => t.status === 'complete').length %>
        <span class="dt-task-pill open"><i class="bi bi-circle me-1"></i><%= open %> open</span>
        <span class="dt-task-pill done"><i class="bi bi-check-circle me-1"></i><%= done %> done</span>
        <form action="/projects/<%= project.id %>/delete" method="POST" onsubmit="return confirm('Delete this project and all its tasks?')" class="d-inline">
          <button type="submit" class="dt-btn-delete"><i class="bi bi-trash3 me-1"></i>Delete Project</button>
        </form>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="dt-card">
          <div class="dt-card-header">
            <span style="font-weight:600; color:rgba(255,255,255,0.85);">Tasks</span>
            <span><%= tasks.length %> total</span>
          </div>
          <% if (tasks.length === 0) { %>
            <div style="text-align:center; padding:3rem; color:rgba(255,255,255,0.3);">
              <i class="bi bi-clipboard2" style="font-size:2rem;"></i>
              <p style="margin-top:0.75rem; margin-bottom:0;">No tasks yet. Add one below.</p>
            </div>
          <% } else { %>
            <ul class="dt-task-list">
              <% tasks.forEach(function(task) { %>
                <li class="dt-task-item <%= task.status === 'complete' ? 'completed' : '' %>">
                  <div class="d-flex align-items-center gap-2 flex-grow-1">

                    <!-- Clickable circle to toggle complete -->
                    <form action="/projects/<%= project.id %>/tasks/<%= task.id %>/complete" method="POST" class="d-inline">
                      <button type="submit" style="background:none;border:none;padding:0;cursor:pointer;display:flex;align-items:center;">
                        <% if (task.status === 'complete') { %>
                          <i class="bi bi-check-circle-fill" style="color:#4ade80;font-size:1.1rem;"></i>
                        <% } else { %>
                          <i class="bi bi-circle" style="color:rgba(255,255,255,0.3);font-size:1.1rem;" onmouseover="this.style.color='#a855f7'" onmouseout="this.style.color='rgba(255,255,255,0.3)'"></i>
                        <% } %>
                      </button>
                    </form>

                    <!-- Inline edit form (hidden by default) -->
                    <form action="/projects/<%= project.id %>/tasks/<%= task.id %>/edit" method="POST" class="d-none flex-grow-1 dt-edit-form-<%= task.id %>">
                      <div class="d-flex gap-2">
                        <input type="text" name="title" value="<%= task.title %>"
                          style="background:rgba(255,255,255,0.07);border:1px solid rgba(168,85,247,0.4);border-radius:6px;color:#fff;padding:0.25rem 0.6rem;font-size:0.9rem;flex:1;" />
                        <button type="submit" style="background:linear-gradient(135deg,#a855f7,#7c3aed);color:#fff;border:none;border-radius:6px;padding:0.25rem 0.75rem;font-size:0.85rem;cursor:pointer;">Save</button>
                        <button type="button" onclick="cancelEdit('<%= task.id %>')" style="background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.6);border:none;border-radius:6px;padding:0.25rem 0.75rem;font-size:0.85rem;cursor:pointer;">Cancel</button>
                      </div>
                    </form>

                    <!-- Task title -->
                    <span class="dt-task-title dt-task-label-<%= task.id %>"><%= task.title %></span>
                  </div>

                  <!-- 3-dot menu -->
                  <div style="position:relative;">
                    <button onclick="toggleMenu('<%= task.id %>')" style="background:none;border:none;color:rgba(255,255,255,0.4);cursor:pointer;padding:0.25rem 0.5rem;font-size:1.1rem;border-radius:6px;" onmouseover="this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.background='none'">
                      <i class="bi bi-three-dots-vertical"></i>
                    </button>
		      <div id="menu-<%= task.id %>" style="display:none;position:absolute;right:0;bottom:100%;background:#1e0035;border:1px solid rgba(168,85,247,0.3);border-radius:10px;min-width:140px;z-index:100;box-shadow:0 8px 24px rgba(0,0,0,0.4);overflow:hidden;margin-bottom:4px;">
                      <button onclick="startEdit('<%= task.id %>')" style="display:block;width:100%;text-align:left;background:none;border:none;color:rgba(255,255,255,0.8);padding:0.65rem 1rem;font-size:0.875rem;cursor:pointer;" onmouseover="this.style.background='rgba(168,85,247,0.15)'" onmouseout="this.style.background='none'">
                        <i class="bi bi-pencil me-2" style="color:#a855f7;"></i>Edit Task
                      </button>
                      <form action="/projects/<%= project.id %>/tasks/<%= task.id %>/delete" method="POST">
                        <button type="submit" style="display:block;width:100%;text-align:left;background:none;border:none;color:rgba(255,255,255,0.8);padding:0.65rem 1rem;font-size:0.875rem;cursor:pointer;" onmouseover="this.style.background='rgba(239,68,68,0.15)'" onmouseout="this.style.background='none'">
                          <i class="bi bi-trash3 me-2" style="color:#f87171;"></i>Delete Task
                        </button>
                      </form>
                    </div>
                  </div>

                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="dt-card">
          <div class="dt-card-header">
            <span style="font-weight:600; color:rgba(255,255,255,0.85);">Add Task</span>
          </div>
          <div class="p-3">
            <form action="/projects/<%= project.id %>/tasks" method="POST">
              <div class="mb-3">
                <input type="text" class="dt-input" name="title" placeholder="Describe the task..." required autocomplete="off" />
              </div>
              <button type="submit" class="dt-btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Add Task
              </button>
            </form>
          </div>
        </div>

        <div class="dt-card">
          <div class="dt-card-header">
            <span style="font-weight:600; color:rgba(255,255,255,0.85);">Project Info</span>
          </div>
          <div class="dt-info-row">
            <span class="dt-info-label">Created</span>
            <span class="dt-info-value"><%= new Date(project.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
          </div>
          <div class="dt-info-row">
            <span class="dt-info-label">Total Tasks</span>
            <span class="dt-info-value"><%= tasks.length %></span>
          </div>
          <% if (tasks.length > 0) { %>
          <div class="dt-info-row">
            <span class="dt-info-label">Progress</span>
            <span class="dt-info-value"><%= Math.round((done / tasks.length) * 100) %>%</span>
          </div>
          <div class="dt-progress-bar">
            <div class="dt-progress-fill" style="width:<%= Math.round((done / tasks.length) * 100) %>%;"></div>
          </div>
          <% } %>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  function toggleMenu(id) {
    document.querySelectorAll('[id^="menu-"]').forEach(m => {
      if (m.id !== 'menu-' + id) m.style.display = 'none';
    });
    const menu = document.getElementById('menu-' + id);
    menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
  }

  function startEdit(id) {
    document.getElementById('menu-' + id).style.display = 'none';
    document.querySelector('.dt-task-label-' + id).style.display = 'none';
    document.querySelector('.dt-edit-form-' + id).classList.remove('d-none');
    document.querySelector('.dt-edit-form-' + id).classList.add('d-flex');
    document.querySelector('.dt-edit-form-' + id + ' input').focus();
  }

  function cancelEdit(id) {
    document.querySelector('.dt-task-label-' + id).style.display = '';
    document.querySelector('.dt-edit-form-' + id).classList.add('d-none');
    document.querySelector('.dt-edit-form-' + id).classList.remove('d-flex');
  }

  document.addEventListener('click', function(e) {
    if (!e.target.closest('[id^="menu-"]') && !e.target.closest('button[onclick^="toggleMenu"]')) {
      document.querySelectorAll('[id^="menu-"]').forEach(m => m.style.display = 'none');
    }
  });
</script>
